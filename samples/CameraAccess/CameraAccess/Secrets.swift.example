// Copy this file to Secrets.swift and fill in your values.
// Secrets.swift is gitignored and will not be committed.

import Foundation

enum Secrets {
  // REQUIRED: Get your key at https://aistudio.google.com/apikey
  static let geminiAPIKey = "YOUR_GEMINI_API_KEY"

  // OPTIONAL: Agent API config (E2B + Claude Agent SDK)
  // Deploy the agent/ directory to Vercel and set these values
  static let agentBaseURL = "https://YOUR_DEPLOYMENT.vercel.app"
  static let agentToken = "YOUR_AGENT_TOKEN"

  // OPTIONAL: OpenClaw agent config (local Mac gateway)
  // Run OpenClaw on your Mac and use its gateway credentials
  static let openClawHost = "http://YOUR_MAC.local"
  static let openClawPort = 18789
  static let openClawHookToken = "YOUR_HOOK_TOKEN"
  static let openClawGatewayToken = "YOUR_GATEWAY_TOKEN"

  // OPTIONAL: WebRTC signaling server URL (for live POV streaming)
  // Run: cd samples/CameraAccess/server && npm install && npm start
  static let webrtcSignalingURL = "ws://YOUR_MAC_IP:8080"

  // OPTIONAL: Google Sign-In (for Calendar + Gmail access)
  // Create an iOS OAuth client at https://console.cloud.google.com/apis/credentials
  // Enable Google Calendar API and Gmail API
  static let googleClientID = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
}
