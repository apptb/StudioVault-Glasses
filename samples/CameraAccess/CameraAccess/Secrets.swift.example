import Foundation

enum Secrets {
  // REQUIRED: Get your key at https://aistudio.google.com/apikey
  static let geminiAPIKey = "YOUR_GEMINI_API_KEY"

  // OPTIONAL: Agent API config (E2B + Claude Agent SDK)
  // Deploy the agent/ directory to Vercel and set these values
  static let agentBaseURL = "https://YOUR_DEPLOYMENT.vercel.app"
  static let agentToken = "YOUR_AGENT_TOKEN"

  // OPTIONAL: WebRTC signaling server URL (for live POV streaming)
  // Run: cd samples/CameraAccess/server && npm install && npm start
  static let webrtcSignalingURL = "ws://YOUR_MAC_IP:8080"
}
